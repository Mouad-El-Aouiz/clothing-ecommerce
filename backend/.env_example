# ============================================================
# DJANGO - CONFIGURATION PRINCIPALE
# ============================================================

# Clé secrète pour chiffrer les sessions et cookies
# Générée avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ⚠️ À GÉNÉRER UNE NOUVELLE POUR VOTRE PROJET
SECRET_KEY=votre_cle_secrete_unique_a_generer

# Mode debug : True = développement, False = production
DEBUG=True

# Domaines autorisés à accéder à l'application
# Séparés par des virgules, sans espaces
ALLOWED_HOSTS=localhost,127.0.0.1


# ============================================================
# STRIPE - PAIEMENT EN LIGNE
# ============================================================

# Clé publique (utilisée par le frontend pour afficher le formulaire)
# Commence par pk_test_ (mode test) ou pk_live_ (mode production)
# Obtenez vos clés sur : https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_votre_cle_publique

# Clé secrète (utilisée par le backend pour créer les paiements)
# ⚠️ NE JAMAIS PARTAGER ou COMMIT SUR GITHUB
STRIPE_SECRET_KEY=sk_test_votre_cle_secrete


# ============================================================
# EMAIL - NOTIFICATIONS DE COMMANDE
# ============================================================

# Serveur SMTP (Simple Mail Transfer Protocol)
# smtp.gmail.com = utilise Gmail pour envoyer les emails
EMAIL_HOST=smtp.gmail.com

# Port de connexion : 587 = TLS (chiffré), 465 = SSL, 25 = non chiffré
EMAIL_PORT=587

# Active le chiffrement TLS pour sécuriser les emails
EMAIL_USE_TLS=True

# Votre adresse Gmail (compte qui envoie les emails)
# ⚠️ Utilisez un email dédié pour la production
EMAIL_HOST_USER=votre_email@gmail.com

# Mot de passe d'application Gmail (16 caractères)
# Généré sur : https://myaccount.google.com/apppasswords
# ⚠️ À GÉNÉRER AVEC VOTRE PROPRE COMPTE
EMAIL_HOST_PASSWORD=votre_mot_de_passe_16_caracteres

# Nom affiché comme expéditeur dans les emails des clients
DEFAULT_FROM_EMAIL=FashionStore <votre_email@gmail.com>


# ============================================================
# CLOUDINARY - STOCKAGE DES IMAGES
# ============================================================

# Nom de votre cloud (trouvé dans le dashboard Cloudinary)
# Inscrivez-vous sur : https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=votre_cloud_name

# Clé API (trouvée dans le dashboard)
CLOUDINARY_API_KEY=votre_api_key

# Secret API (à garder SECRET - ne JAMAIS partager)
CLOUDINARY_API_SECRET=votre_api_secret

# Optionnel : dossiers de stockage
CLOUDINARY_PRODUCTS_FOLDER=products
CLOUDINARY_CATEGORIES_FOLDER=categories
CLOUDINARY_AVATARS_FOLDER=avatars


# ============================================================
# OPTIONS POUR LA PRODUCTION (À DÉCOMMENTER PLUS TARD)
# ============================================================

# Frontend URL (pour les liens dans les emails)
# FRONTEND_URL=https://votre-domaine.com

# Base de données PostgreSQL (plus robuste que SQLite)
# Décommentez quand vous passez en production
# DATABASE_URL=postgresql://utilisateur:motdepasse@localhost:5432/nomdelabase

# Pour SendGrid (alternative à Gmail)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=votre_sendgrid_api_key